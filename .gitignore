# ==============================================================================
# .gitignore for Academic Claude Code Projects
# ==============================================================================

# LaTeX build artifacts
*.aux
*.bbl
*.blg
*.fdb_latexmk
*.fls
*.log
*.nav
*.out
*.snm
*.toc
*.vrb
*.synctex.gz
*.run.xml
*-blx.bib
*.xdv

# Compiled PDFs — ignore the built manuscript, but keep source PDFs
# (e.g. references/*.pdf are literature we want tracked)
paper/main.pdf
paper/**/*.pdf

# Python
__pycache__/
*.pyc
*.pyo

# R
.Rproj.user/
.Rhistory
.RData
.Rdata

# OS files
.DS_Store
Thumbs.db

# Claude Code local files (not shared across machines)
.claude/settings.local.json
.claude/state/*
!.claude/state/*.example

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Quarto rendering artifacts
/.quarto/
paper/quarto/*_files/
paper/quarto/.quarto/

# Output artifacts — uncomment lines below based on your preference
# *.rds
# output/**/*.rds
docs/

# Generated HTML reports (regenerated by scripts/generate_dashboard.py and generate_html_report.py)
project_dashboard.html
quality_reports/**/*.html
